<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nav">
        <div class="container">
            <div class="logo">
                <h2 style="color: white; margin: 0;">📝 Написать письмо</h2>
            </div>
            <div class="nav-links">
                <% navLinks.forEach(link=> { %>
                    <a href="<%= link.href %>" class="btn btn-secondary">
                        <%= link.text %>
                    </a>
                    <% }); %>
            </div>
        </div>
    </nav>

    <div class="container">
        <% if (error) { %>
            <div class="error">
                <strong>Ошибка:</strong>
                <%= error %>
            </div>
            <% } %>

                <div class="form-container">
                    <h1>Напишите письмо Деду Морозу</h1>

                    <form method="POST" action="/letter">
                        <div class="form-group">
                            <label for="name" class="required">Ваше имя:</label>
                            <input type="text" id="name" name="name" value="<%= old.name || '' %>"
                                placeholder="Например: Маша или Петя" required>
                        </div>

                        <div class="form-group">
                            <label for="age" class="required">Ваш возраст:</label>
                            <input type="number" id="age" name="age" value="<%= old.age || '' %>" min="3" max="12"
                                placeholder="От 3 до 12 лет" required>
                        </div>

                        <div class="form-group">
                            <label for="wish" class="required">Ваше желание:</label>
                            <textarea id="wish" name="wish"
                                placeholder="Напишите, что вы хотите на Новый год (не более 200 символов)..."
                                maxlength="200" required><%= old.wish || '' %></textarea>
                            <div style="text-align: right; margin-top: 5px; color: #666;">
                                <span id="charCount">0</span>/200 символов
                            </div>
                        </div>

                        <div style="text-align: center; margin-top: 30px;">
                            <button type="submit" class="btn btn-large">✉️ Отправить письмо</button>
                        </div>
                    </form>
                </div>

                <div style="text-align: center; margin-top: 20px;">
                    <a href="/" class="btn btn-secondary">← Вернуться на главную</a>
                </div>
    </div>

    <script>
        // Счетчик символов
        const textarea = document.getElementById('wish');
        const charCount = document.getElementById('charCount');

        textarea.addEventListener('input', function () {
            charCount.textContent = this.value.length;

            if (this.value.length > 180) {
                charCount.style.color = '#d32f2f';
                charCount.style.fontWeight = 'bold';
            } else if (this.value.length > 150) {
                charCount.style.color = '#ff9800';
            } else {
                charCount.style.color = '#666';
            }
        });

        // Инициализация счетчика
        charCount.textContent = textarea.value.length;
    </script>
</body>

</html>